# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Docker Compose: postgresql://user:password@postgres:5432/recoflow
# Local dev:      postgresql://user:password@localhost:5432/recoflow
POSTGRES_URL=postgresql://user:password@postgres:5432/recoflow

# ── Redis ─────────────────────────────────────────────────────────────────────
# Docker Compose: redis://redis:6379
# Local dev:      redis://localhost:6379
REDIS_URL=redis://redis:6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Docker Compose uses the INTERNAL listener on port 29092
# Local dev uses the EXTERNAL listener on port 9092
KAFKA_BROKERS=kafka:29092

# ── Feature flags ─────────────────────────────────────────────────────────────
# Enable Redis response caching (TTL 60s) for recommendation results
CACHE_ENABLED=true

# Return popular fallback items instead of 500 when ranking service fails
FALLBACK_ENABLED=true

# Enable @fastify/rate-limit globally (100 req / 60s per IP by default)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Enable request-level analytics logging
FEATURE_ANALYTICS=true
